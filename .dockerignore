# Keep the build context lean — only Go sources and the static web assets.
.git
.gitignore
.jj
.claude
.playwright-mcp
# Test/debug screenshots are PNGs at repo root. Exclude all PNGs then
# explicitly re-include the html/img/ sprite atlases the client needs.
*.png
!html/img/*.png
*.md
*_test.go
Dockerfile
.dockerignore

# Mac noise
.DS_Store

# Editor / IDE
*.swp
*.swo
.idea
.vscode

# Source-only artifacts we don't ship
sprites/
.travis.yml
